{
    "name": "ae-bootcamp-demo",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspace",
    "customizations": {
        "vscode": {
            "extensions": [
                "github.copilot",
                "github.copilot-chat",
                "shopify.ruby-extensions-pack",
                "Shopify.vscode-ruby-lsp",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker",
                "ms-azuretools.vscode-azureterraform",
                "ms-vscode.azurecli",
                "opentofu.vscode-opentofu",
                "github.vscode-github-actions",
                "ms-azuretools.vscode-azure-github-copilot",
                "ms-ossdata.vscode-postgresql",
                "infracost.infracost"
            ],
            "settings": {}
        }
    },
    "postCreateCommand": "cd /workspace/blog && bundle install && bundle exec overcommit --install && bundle exec overcommit --sign",
    "forwardPorts": [
        4567,
        5432
    ],
    "portsAttributes": {
        "4567": {
            "label": "blog app"
        },
        "5432": {
            "label": "postgres"
        }
    }
}