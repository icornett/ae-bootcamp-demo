#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

chmod +x "$REPO_ROOT/.githooks/pre-push"
chmod +x "$REPO_ROOT/scripts/check-ghcr-latest-digest.sh"

git -C "$REPO_ROOT" config core.hooksPath .githooks

echo "Git hooks installed."
echo "pre-push now checks GHCR latest digest changes."
